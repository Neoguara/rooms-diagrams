@startuml update_room_type

title PUT /room-types/{id} — Atualizar Tipo de Sala

actor User
boundary "Frontend" as FE
participant "RoomTypeController" as Ctrl
participant "UpdateRoomTypeUseCase" as UC
participant "RoomTypeMapper" as Mapper
participant "RoomType" as Entity
participant "RoomTypeRepositoryPort" as Repo
database "room_types" as DB

User -> FE: edita dados e confirma
activate FE
FE -> Ctrl: PUT /room-types/{id}\n{name, description, defaultCapacity, color, icon}
activate Ctrl

Ctrl -> UC: execute(id, UpdateRoomTypeRequest)
activate UC

UC -> Repo: findById(RoomTypeId.of(id))
activate Repo
Repo -> DB: SELECT * FROM room_types WHERE id=?
DB --> Repo: Optional<RoomType>
Repo --> UC: Optional<RoomType>
deactivate Repo

alt not found
  UC --> Ctrl: ResourceNotFoundException
  Ctrl --> FE: 404 Not Found
  FE --> User: exibe erro
else found
  UC -> Entity: update(name, description, defaultCapacity, color, icon)
  activate Entity
  note right of Entity: RoomTypeValidation.validate()\nupdatedAt = now()
  Entity --> UC:
  deactivate Entity

  UC -> Repo: save(roomType)
  activate Repo
  Repo -> DB: UPDATE room_types SET\nname=?, description=?, ..., updated_at=?
  DB --> Repo: roomType
  Repo --> UC: saved
  deactivate Repo

  UC -> Mapper: toResponse(saved)
  activate Mapper
  Mapper --> UC: RoomTypeResponse
  deactivate Mapper

  UC --> Ctrl: RoomTypeResponse
  Ctrl --> FE: 200 OK {RoomTypeResponse}
  FE --> User: exibe dados atualizados
end

deactivate UC
deactivate Ctrl
deactivate FE

@enduml
