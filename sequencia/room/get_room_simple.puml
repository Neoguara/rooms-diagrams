@startuml get_room_simple

title GET /rooms e GET /rooms/{id} — Buscar Sala

actor User
boundary "Frontend" as FE
participant "RoomController" as Ctrl
participant "GetRoomUseCase" as UC
participant "RoomMapper" as Mapper
participant "RoomRepositoryPort" as Repo
database "rooms" as DB

== Listar todas ==

User -> FE: solicita listagem de salas
activate FE
FE -> Ctrl: GET /rooms
activate Ctrl

Ctrl -> UC: findAll()
activate UC

UC -> Repo: findAll()
activate Repo
Repo -> DB: SELECT * FROM rooms\nWHERE status != DELETED
DB --> Repo: List<Room>
Repo --> UC: List<Room>
deactivate Repo

UC -> Mapper: toDetailResponse(each room, null, null, null)
activate Mapper
Mapper --> UC: List<RoomDetailResponse>
deactivate Mapper

UC --> Ctrl: List<RoomDetailResponse>
deactivate UC
Ctrl --> FE: 200 OK {List<RoomDetailResponse>}
deactivate Ctrl
FE --> User: exibe listagem
deactivate FE

== Buscar por ID ==

User -> FE: solicita busca por ID
activate FE
FE -> Ctrl: GET /rooms/{id}
activate Ctrl

Ctrl -> UC: findById(id)
activate UC

UC -> Repo: findById(RoomId.of(id))
activate Repo
Repo -> DB: SELECT * FROM rooms WHERE id=?
DB --> Repo: Optional<Room>
Repo --> UC: Optional<Room>
deactivate Repo

alt found
  UC -> Mapper: toDetailResponse(room, null, null, null)
  activate Mapper
  Mapper --> UC: RoomDetailResponse
  deactivate Mapper

  UC --> Ctrl: RoomDetailResponse
  Ctrl --> FE: 200 OK {RoomDetailResponse}
  FE --> User: exibe dados da sala
else not found
  UC --> Ctrl: ResourceNotFoundException
  Ctrl --> FE: 404 Not Found
  FE --> User: exibe erro
end

deactivate UC
deactivate Ctrl
deactivate FE

@enduml
