@startuml update_room

title PUT /rooms/{id} — Atualizar Sala

actor User
boundary "Frontend" as FE
participant "RoomController" as Ctrl
participant "UpdateRoomUseCase" as UC
participant "RoomMapper" as Mapper
participant "Room" as Entity
participant "RoomRepositoryPort" as Repo
database "rooms" as DB

User -> FE: edita dados e confirma
activate FE
FE -> Ctrl: PUT /rooms/{id}\n{name, code, roomTypeId, buildingId, floor, capacity}
activate Ctrl

Ctrl -> UC: execute(id, UpdateRoomRequest)
activate UC

UC -> Repo: findById(RoomId.of(id))
activate Repo
Repo -> DB: SELECT * FROM rooms WHERE id=?
DB --> Repo: Optional<Room>
Repo --> UC: Optional<Room>
deactivate Repo

alt not found
  UC --> Ctrl: ResourceNotFoundException
  Ctrl --> FE: 404 Not Found
  FE --> User: exibe erro
else found
  UC -> Entity: update(name, code, roomTypeId, buildingId, floor, capacity)
  activate Entity
  note right of Entity: RoomValidator.validate()\nupdatedAt = now()
  Entity --> UC:
  deactivate Entity

  UC -> Repo: save(room)
  activate Repo
  Repo -> DB: UPDATE rooms SET\nname=?, code=?, room_type_id=?,\nbuilding_id=?, floor=?, capacity=?, updated_at=?
  DB --> Repo: room
  Repo --> UC: saved
  deactivate Repo

  UC -> Mapper: toResponse(saved)
  activate Mapper
  Mapper --> UC: RoomResponse
  deactivate Mapper

  UC --> Ctrl: RoomResponse
  Ctrl --> FE: 200 OK {RoomResponse}
  FE --> User: exibe dados atualizados
end

deactivate UC
deactivate Ctrl
deactivate FE

@enduml
