@startuml get_resource

title GET /resources e GET /resources/{id} — Buscar Recurso

actor User
boundary "Frontend" as FE
participant "ResourceController" as Ctrl
participant "GetResourceUseCase" as UC
participant "ResourceMapper" as Mapper
participant "ResourceRepositoryPort" as Repo
database "resources" as DB

== Listar todos ==

User -> FE: solicita listagem de recursos
activate FE
FE -> Ctrl: GET /resources
activate Ctrl
Ctrl -> UC: findAll()
activate UC

UC -> Repo: findAll()
activate Repo
Repo -> DB: SELECT * FROM resources\nWHERE status != DELETED
DB --> Repo: List<Resource>
Repo --> UC: List<Resource>
deactivate Repo

UC -> Mapper: toResponse(each resource)
activate Mapper
Mapper --> UC: List<ResourceResponse>
deactivate Mapper

UC --> Ctrl: List<ResourceResponse>
deactivate UC
Ctrl --> FE: 200 OK {List<ResourceResponse>}
deactivate Ctrl
FE --> User: exibe listagem
deactivate FE

== Buscar por ID ==

User -> FE: solicita busca por ID
activate FE
FE -> Ctrl: GET /resources/{id}
activate Ctrl
Ctrl -> UC: findById(id)
activate UC

UC -> Repo: findById(ResourceId.of(id))
activate Repo
Repo -> DB: SELECT * FROM resources\nWHERE id=? AND status!=DELETED
DB --> Repo: Optional<Resource>
Repo --> UC: Optional<Resource>
deactivate Repo

alt found
  UC -> Mapper: toResponse(resource)
  activate Mapper
  Mapper --> UC: ResourceResponse
  deactivate Mapper
  UC --> Ctrl: ResourceResponse
  Ctrl --> FE: 200 OK {ResourceResponse}
  FE --> User: exibe dados
else not found
  UC --> Ctrl: ResourceNotFoundException
  Ctrl --> FE: 404 Not Found
  FE --> User: exibe erro
end

deactivate UC
deactivate Ctrl
deactivate FE

@enduml
