@startuml delete_user

title DELETE /users/{id} — Remover Usuário (Soft Delete)

actor User
boundary "Frontend" as FE
participant "UserController" as Ctrl
participant "DeleteUserUseCase" as UC
participant "User" as Entity
participant "UserRepositoryPort" as Repo
database "users" as DB

User -> FE: solicita exclusão do usuário
activate FE
FE -> Ctrl: DELETE /users/{id}
activate Ctrl

Ctrl -> UC: execute(id)
activate UC

UC -> Repo: findById(UserId.of(id))
activate Repo
Repo -> DB: SELECT * FROM users WHERE id=?
DB --> Repo: Optional<User>
Repo --> UC: Optional<User>
deactivate Repo

alt found
  UC -> Entity: delete()
  activate Entity
  note right of Entity: status = DELETED
  Entity --> UC:
  deactivate Entity

  UC -> Repo: delete(user)
  activate Repo
  Repo -> DB: UPDATE users SET status = DELETED
  DB --> Repo:
  Repo --> UC:
  deactivate Repo

  UC --> Ctrl: void
  Ctrl --> FE: 204 No Content
  FE --> User: exibe confirmação de exclusão
else not found
  UC --> Ctrl: ResourceNotFoundException
  Ctrl --> FE: 404 Not Found
  FE --> User: exibe erro
end

deactivate UC
deactivate Ctrl
deactivate FE

@enduml
