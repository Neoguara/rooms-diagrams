@startuml der

skinparam linetype ortho

' ── users ──────────────────────────────────────────────
entity "users" as User {
  * id : UUID <<PK>>
  --
  name : VARCHAR
  email : VARCHAR <<unique>>
  password : VARCHAR
  role : VARCHAR
  status : VARCHAR
  created_at : TIMESTAMP
  updated_at : TIMESTAMP
}

' ── buildings ──────────────────────────────────────────
entity "buildings" as Building {
  * id : UUID <<PK>>
  --
  name : VARCHAR
  address : VARCHAR
  total_floors : INTEGER
  status : VARCHAR
  created_at : TIMESTAMP
  updated_at : TIMESTAMP
}

' ── room_types ─────────────────────────────────────────
entity "room_types" as RoomType {
  * id : UUID <<PK>>
  --
  name : VARCHAR
  description : VARCHAR
  default_capacity : VARCHAR
  color : VARCHAR
  icon : VARCHAR
  status : VARCHAR
  created_at : TIMESTAMP
  updated_at : TIMESTAMP
}

' ── rooms ──────────────────────────────────────────────
entity "rooms" as Room {
  * id : UUID <<PK>>
  --
  * building_id : UUID <<FK>>
  * room_type_id : UUID <<FK>>
  name : VARCHAR
  code : VARCHAR
  floor : INTEGER
  capacity : INTEGER
  status : VARCHAR
  created_at : TIMESTAMP
  updated_at : TIMESTAMP
}

' ── resources ──────────────────────────────────────────
entity "resources" as Resource {
  * id : UUID <<PK>>
  --
  name : VARCHAR
  description : VARCHAR
  icon : VARCHAR
  status : VARCHAR
  created_at : TIMESTAMP
  updated_at : TIMESTAMP
}

' ── room_resources ─────────────────────────────────────
entity "room_resources" as RoomResource {
  * id : UUID <<PK>>
  --
  * room_id : UUID <<FK>>
  * resource_id : UUID <<FK>>
  created_at : TIMESTAMP
}

' ── events ─────────────────────────────────────────────
entity "events" as Event {
  * id : UUID <<PK>>
  --
  * room_id : UUID <<FK>>
  title : VARCHAR
  description : TEXT
  start_at : TIMESTAMP
  end_at : TIMESTAMP
  is_all_day : BOOLEAN
  recurrence_rule : VARCHAR
  status : VARCHAR
  created_at : TIMESTAMP
  updated_at : TIMESTAMP
}

' ── event_requests ─────────────────────────────────────
entity "event_requests" as EventRequest {
  * id : UUID <<PK>>
  --
  event_id : UUID <<FK>>
  * created_by : UUID <<FK>>
  status : VARCHAR
  type : VARCHAR
  justification : TEXT
  created_at : TIMESTAMP
}

' ── event_change_items ─────────────────────────────────
entity "event_change_items" as EventChangeItem {
  * id : UUID <<PK>>
  --
  * event_request_id : UUID <<FK>>
  before_room_id : UUID
  before_title : VARCHAR
  before_description : TEXT
  before_start_at : TIMESTAMP
  before_end_at : TIMESTAMP
  before_is_all_day : BOOLEAN
  before_recurrence_rule : VARCHAR
  after_room_id : UUID
  after_title : VARCHAR
  after_description : TEXT
  after_start_at : TIMESTAMP
  after_end_at : TIMESTAMP
  after_is_all_day : BOOLEAN
  after_recurrence_rule : VARCHAR
}

' ── Relacionamentos ────────────────────────────────────
Building      ||--o{ Room
RoomType      ||--o{ Room

Room          ||--o{ RoomResource
Resource      ||--o{ RoomResource

Room          ||--o{ Event

User          ||--o{ EventRequest
Event         |o--o{ EventRequest

EventRequest  ||--o| EventChangeItem

@enduml
