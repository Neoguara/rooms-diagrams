@startuml

skinparam linetype ortho
skinparam packageStyle rectangle

package "Domain" #EEF2FF {

  package "entities" {
    class User {
      - UserId id
      - String name
      - String email
      - String password
      - UserRole role
      - UserStatus status
      - LocalDateTime createdAt
      - LocalDateTime updatedAt
      + {static} User create(String,String,String,UserRole)
      + void update(String,String,String,UserRole)
      + void activate()
      + void deactivate()
      + void delete()
    }
  }

  package "valueobjects" {
    class UserId {
      - UUID id
      + {static} UserId of(UUID)
      + UUID id()
    }
  }

  package "enums" {
    enum UserRole {
      ADMIN
      USER
    }
    enum UserStatus {
      ACTIVE
      INACTIVE
      DELETED
    }
  }

  package "validation" {
    class UserValidator {
      + void validate(User,Notification)
    }
  }
}

package "Application" #F0FFF0 {

  package "ports" {
    interface UserRepositoryPort {
      ~ User save(User)
      ~ Optional<User> findById(UserId)
      ~ List<User> findAll()
      ~ Optional<User> findByEmail(String)
      ~ boolean existsByEmail(String)
      ~ void delete(User)
    }
  }

  package "mappers" {
    class UserMapper {
      + {static} User toDomain(CreateUserRequest,String)
      + {static} UserResponse toResponse(User)
    }
  }

  package "usecases" {
    class CreateUserUseCase {
      - UserRepositoryPort repository
      - PasswordEncoder passwordEncoder
      + UserResponse execute(CreateUserRequest)
    }
    class GetUserUseCase {
      - UserRepositoryPort repository
      + UserResponse findById(UUID)
      + List<UserResponse> findAll()
    }
    class UpdateUserUseCase {
      - UserRepositoryPort repository
      - PasswordEncoder passwordEncoder
      + UserResponse execute(UUID,UpdateUserRequest)
    }
    class UpdateUserStatusUseCase {
      - UserRepositoryPort repository
      + UserResponse execute(UUID,UpdateUserStatusRequest.Status)
    }
    class DeleteUserUseCase {
      - UserRepositoryPort repository
      + void execute(UUID)
    }
  }

  package "dtos" {
    class CreateUserRequest {
      - String name
      - String email
      - String password
      - UserRole role
    }
    class UpdateUserRequest {
      - String name
      - String email
      - String password
      - UserRole role
    }
    class UpdateUserStatusRequest {
      - Status status
    }
    class UserResponse {
      - UUID id
      - String name
      - String email
      - UserRole role
      - UserStatus status
      - LocalDateTime createdAt
      - LocalDateTime updatedAt
    }
    enum Status {
      ACTIVE
      INACTIVE
    }
  }
}

package "Infrastructure" #FFF8F0 {

  package "web" {
    class UserController {
      - CreateUserUseCase createUserUseCase
      - GetUserUseCase getUserUseCase
      - UpdateUserUseCase updateUserUseCase
      - UpdateUserStatusUseCase updateUserStatusUseCase
      - DeleteUserUseCase deleteUserUseCase
      + ResponseEntity<UserResponse> create(CreateUserRequest)
      + ResponseEntity<List<UserResponse>> findAll()
      + ResponseEntity<UserResponse> findById(UUID)
      + ResponseEntity<UserResponse> update(UUID,UpdateUserRequest)
      + ResponseEntity<Void> deleteById(UUID)
      + ResponseEntity<UserResponse> updateStatus(UUID,UpdateUserStatusRequest)
    }
  }

  package "repositories" {
    class UserRepositoryImpl {
      - UserJpaRepository jpaRepository
      + User save(User)
      + Optional<User> findById(UserId)
      + List<User> findAll()
      + Optional<User> findByEmail(String)
      + boolean existsByEmail(String)
      + void delete(User)
    }
    interface UserJpaRepository {
      ~ Optional<User> findByEmail(String)
      ~ boolean existsByEmail(String)
      ~ List<User> findAllByStatusNot(UserStatus)
      ~ Optional<User> findByIdAndStatusNot(UserId,UserStatus)
      ~ Optional<User> findByEmailAndStatusNot(String,UserStatus)
      ~ boolean existsByEmailAndStatusNot(String,UserStatus)
    }
  }

  package "auth" {
    class UserAuthAdapter {
      - UserRepositoryPort userRepository
      + Optional<AuthUserData> findByEmail(String)
    }
  }
}

' Herança / Implementação
rooms.shared.domain.validation.Validator <|.. UserValidator
UserRepositoryPort <|.. UserRepositoryImpl
rooms.auth.UserAuthPort <|.. UserAuthAdapter
JpaRepository <|-- UserJpaRepository

' Controller -> UseCases
UserController --> CreateUserUseCase
UserController --> GetUserUseCase
UserController --> UpdateUserUseCase
UserController --> UpdateUserStatusUseCase
UserController --> DeleteUserUseCase

' Controller -> DTOs
UserController ..> CreateUserRequest
UserController ..> UpdateUserRequest
UserController ..> UpdateUserStatusRequest
UserController ..> UserResponse

' UseCases -> UserRepositoryPort
CreateUserUseCase --> UserRepositoryPort
GetUserUseCase --> UserRepositoryPort
UpdateUserUseCase --> UserRepositoryPort
UpdateUserStatusUseCase --> UserRepositoryPort
DeleteUserUseCase --> UserRepositoryPort

' UseCases -> UserMapper
CreateUserUseCase ..> UserMapper
GetUserUseCase ..> UserMapper
UpdateUserUseCase ..> UserMapper
UpdateUserStatusUseCase ..> UserMapper

' UserMapper -> DTOs e domínio
UserMapper ..> CreateUserRequest
UserMapper ..> UserResponse
UserMapper ..> User

' Infrastructure
UserRepositoryImpl --> UserJpaRepository
UserAuthAdapter --> UserRepositoryPort

' Domínio: User -> composição e enums
User *-- UserId
User --> UserRole
User --> UserStatus

' Validator -> User
UserValidator ..> User

' DTOs -> Enums
CreateUserRequest ..> UserRole
UpdateUserRequest ..> UserRole
UserResponse ..> UserRole
UserResponse ..> UserStatus
UpdateUserStatusRequest *-- Status

' JpaRepository -> domínio
UserJpaRepository ..> User
UserJpaRepository ..> UserId
UserJpaRepository ..> UserStatus

@enduml
